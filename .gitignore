# dependencies
/node_modules

# testing
/coverage
/tests/screenshots
/playwright-report
/test-results

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.playwright-mcp/
.claude/

# debug
npm-debug.log*
